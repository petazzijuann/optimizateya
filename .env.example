# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-token-de-botfather
TELEGRAM_WEBHOOK_SECRET=cambiame-por-un-uuid
PUBLIC_BASE_URL=https://tu-dominio-publico.example.com

# --- Infraestructura ---
DATABASE_URL=postgresql+asyncpg://optimizateya:optimizateya@localhost:5433/optimizateya
REDIS_URL=redis://localhost:6380/0

# --- LLM (gratuito: Groq u Ollama, OpenAI-compatible) ---
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama-3.1-8b-instant
LLM_MODEL_HEAVY=llama-3.3-70b-versatile
VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
EMBED_MODEL=nomic-embed-text
STT_MODEL=whisper-large-v3-turbo
LLM_MONTHLY_BUDGET_TOKENS=2000000

# --- Storage (elegí UNO; si los dos están, gana Cloudinary) ---
# Cloudinary (gratis 25GB): cloudinary.com → Dashboard → "API environment variable"
CLOUDINARY_URL=

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=optimizateya

# --- Seguridad ---
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- OAuth calendarios (opcional en dev) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# --- Observabilidad (opcional) ---
SENTRY_DSN=
ENVIRONMENT=dev
